# Your Anthropic API key. Get one at https://console.anthropic.com/
# Copy this file to .env.local and paste your key below.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (defaults to claude-opus-4-8)
# JARVIS_MODEL=claude-opus-4-8

# Optional: what JARVIS calls you (defaults to "sir")
# JARVIS_ADDRESS=sir

# Optional: live web search is ON by default. Set to 0 to disable it.
# JARVIS_WEB_SEARCH=1
